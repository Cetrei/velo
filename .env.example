# Velo — environment configuration
# Port the signaling server (Express + Socket.IO) listens on inside the container/process.
VELO_SIGNALING_PORT=4001

# Origin allowed by the signaling server's CORS policy (Socket.IO connections). This MUST match
# wherever apps/web is actually being loaded from by the Tauri desktop app and browser clients
# (i.e. it must match VELO_PAGES_URL below in the common case). Defaults to https://velo.cetrei.dev
# in code if unset.
#   - Cloudflare Pages + Cloudflare Tunnel flow (docker compose, the primary deployment target):
#     set this to your VELO_PAGES_URL value, e.g. https://velo.cetrei.dev
#   - Fully local dev flow (bun run dev:server + bun run dev:web on localhost, no Docker):
#     set this to your local web dev origin, e.g. http://localhost:4000
VELO_ALLOWED_ORIGIN=https://velo.cetrei.dev

# Cloudflare Tunnel token, from the Zero Trust dashboard: Networks > Tunnels > (your tunnel) > Configure > install a connector.
# Only needed if you're running the PC fallback path. The primary deployment target is Railway; see docs/MANUAL_STEPS.md.
CLOUDFLARE_TUNNEL_TOKEN=

# Public hostname you routed to this tunnel in the Cloudflare dashboard, used only for reference/logging.
VELO_PUBLIC_HOSTNAME=velo-server.cetrei.dev

# Full base URL of the Cloudflare Pages deployment (apps/web build). The Tauri desktop app and the
# Capacitor Android app both load this URL directly at runtime instead of bundling apps/web/dist
# locally, so publishing a new apps/web build updates every installed .exe and .apk without a rebuild.
VELO_PAGES_URL=https://velo.cetrei.dev

# Path to a JDK 21 installation, used only when building the Android APK (apps/web/android).
# Gradle's bundled toolchain resolution can pick up a system-default JDK that's too new (e.g. JDK 25,
# "Unsupported class file major version 69")
VELO_ANDROID_JAVA_HOME=
