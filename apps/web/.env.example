# Velo web — build-time environment configuration
# Copy this file to `.env` inside apps/web/ (or `.env.production` for Cloudflare Pages builds specifically).

# Full base URL of the signaling server. Primary target is Railway (always-on); the Cloudflare Tunnel
# to your PC is the fallback path, same hostname either way since only the DNS target changes.ocalhost.
VITE_SIGNALING_URL=https://velo-server.cetrei.dev
