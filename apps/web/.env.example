# Velo web — build-time environment configuration
# Copy this file to `.env` inside apps/web/ (or `.env.production` for Cloudflare Pages builds specifically).

# Full base URL of the signaling server. Primary target is Railway (always-on); the Cloudflare Tunnel
# to your PC is the fallback path, same hostname either way since only the DNS target changes.
VITE_SIGNALING_URL=https://velo-server.cetrei.dev

# GitHub repo (owner/name) the Downloads page pulls published releases from directly, without
# going through the signaling server. Optional, defaults to Cetrei/velo if unset.
VITE_RELEASES_REPO=Cetrei/velo
