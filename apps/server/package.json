{
  "name": "server",
  "version": "0.1.0",
  "private": true,

  "type": "module",
  "module": "src/index.ts",

  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "compile": "bun build ./src/index.ts --compile --define VELO_BACKEND_VERSION=\"\\\"$npm_package_version\\\"\" --outfile ../../bin/backend/velo-backend.exe --target=bun-windows-x64"
  },

  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "socket.io": "^4.8.3",
    "yaml": "^2.9.0",
    "shared-types": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^26.1.1"
  }
}
