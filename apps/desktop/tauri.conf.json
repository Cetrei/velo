{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velo",
  "version": "0.3.1",
  "identifier": "com.cetrei.velo",
  "build": {
    "devUrl": "http://localhost:4000",
    "frontendDist": "../web/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 420,
        "height": 280,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["assets/icon.ico"],
    "resources": {
      "resources/obs-virtualsource.dll": "resources/obs-virtualsource.dll",
      "../../config/system.yml": "config/system.yml",
      "../../config/user.yml": "config/user.yml"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": true,
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/Cetrei/velo/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFFQUNCM0ZFOUU2QjRBNEMKUldSTVNtdWUvck9zSG56d1FybkdwRzVWWWRXUGc2dkQ1N1ErMFpHMGpLMmlxVU5nQmlUMHdqbGEK"
    }
  }
}
