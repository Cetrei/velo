# Copy this file to keystore.properties (same directory) for local release builds.
# keystore.properties is gitignored, never commit it or the .jks/.keystore file itself.
#
# Generate the keystore once with:
#   keytool -genkeypair -v -keystore velo-upload.keystore -keyalg RSA -keysize 2048 -validity 10000 -alias velo
#
# storeFile is resolved relative to apps/web/android/app/, so keep the .keystore file
# either there or reference it with an absolute path.

storeFile=velo-upload.keystore
storePassword=CHANGE_ME
keyAlias=velo
keyPassword=CHANGE_ME
